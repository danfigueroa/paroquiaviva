# Copy to .env.local for local dev. In production, set these in Vercel
# (Settings → Environment Variables) instead of committing them.

# Backend API base URL (include /api/v1).
# Dev local: http://localhost:8080/api/v1
# Prod (Vercel multi-service): /_/backend/api/v1
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Supabase project URL — Project Settings → API → Project URL.
VITE_SUPABASE_URL=https://hkybwprhrhajvnklpgiz.supabase.co

# Supabase anon (public) key — Project Settings → API → anon public.
# Safe to ship to the browser; never put the service_role key here.
VITE_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
